rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student_manager' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher_manager'
      );
    }

    function isTeacher() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    function getTeacherId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teacherId;
    }

    // Users collection - auth metadata
    match /users/{uid} {
      allow read: if (resource != null && resource.data.role == 'teacher') || (isAuthenticated() && (request.auth.uid == uid || isAdmin()));
      allow create, update: if isAdmin() || (isAuthenticated() && request.auth.uid == uid && (resource == null || resource.data.role == 'teacher') && request.resource.data.role == 'teacher');
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == uid);
    }

    // Students collection
    match /students/{studentId} {
      allow read: if true; // Public read for lookup by student code on tracking page
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Teachers collection
    match /teachers/{teacherId} {
      allow read: if true; // Public read for teacher code verification during login
      allow update: if isAdmin() || (isTeacher() && request.auth.uid == resource.data.uid);
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    // Subjects collection
    match /subjects/{subjectId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Branches collection
    match /branches/{branchId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Lessons collection
    match /lessons/{lessonId} {
      allow create: if isTeacher() && getTeacherId() == request.resource.data.teacherId;
      allow read: if isAdmin() 
                   || (isTeacher() && getTeacherId() == resource.data.teacherId);
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Public lessons collection for parents
    match /publicLessons/{lessonId} {
      allow read: if resource.data.status == 'approved';
      allow write: if isAdmin();
    }

    // Payroll collection
    match /payroll/{payrollId} {
      allow read: if isAdmin() || (isTeacher() && getTeacherId() == resource.data.teacherId);
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Admin Logs collection
    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow delete: if false;
    }

    // Teacher Availability collection
    match /teacherAvailability/{teacherId} {
      allow read: if true;
      allow write: if isAdmin() || (isTeacher() && getTeacherId() == teacherId);
    }

    // Booking requests from public teacher page
    match /bookingRequests/{requestId} {
      allow create: if isAdmin() || (
                    request.resource.data.status == 'pending'
                    && request.resource.data.teacherId is string
                    && request.resource.data.studentId is string
                    && request.resource.data.studentCode is string
                    && request.resource.data.requestedMinutes is int
                    && request.resource.data.requestedMinutes in [25, 50, 75, 100]
                    );
      allow read: if true;
      allow update: if isAdmin() || (isTeacher() && resource.data.teacherId == getTeacherId());
      allow delete: if isAdmin();
    }

    // Contracts collection
    match /contracts/{contractId} {
      allow read: if isAdmin() || (isTeacher() && resource.data.teacherId == getTeacherId());
      allow create: if isAdmin() || (isTeacher() && request.resource.data.teacherId == getTeacherId());
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Evaluations collection
    match /evaluations/{evaluationId} {
      allow read: if true;
      allow write: if isAdmin() || isTeacher();
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if isAdmin() || (isTeacher() && resource.data.targetType == 'teachers');
      allow write: if isAdmin();
    }

    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
